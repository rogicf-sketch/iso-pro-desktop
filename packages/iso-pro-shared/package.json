{
  "name": "iso-pro-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Contrato TypeScript (e validadores opcionais) do payload iso_pro_snapshot entre I.S.O PRO desktop e app campo.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "default": "./dist/validators.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run build && npm run test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  }
}

# Copie para `scripts/backup-oci.env` (ficheiro gitignored).
# Requer OCI CLI configurado: oci setup config
# Bucket criado na consola Oracle Object Storage.

OCI_BUCKET_NAME=iso-pro-backups
OCI_PREFIX=iso-pro-snapshots

# Opcional: encriptação AES-256-GCM antes do upload (64 hex = 32 bytes, ou passphrase)
# BACKUP_ENCRYPTION_KEY=

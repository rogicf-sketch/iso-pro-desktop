{
  "name": "iso-pro-desktop",
  "description": "I.S.O PRO — aplicação desktop (Electron + Vite)",
  "author": "I.S.O PRO Gestão de Materiais",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "version": "0.1.15",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:browser": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/run-electron-dev.mjs",
    "open:app": "start http://127.0.0.1:5173/",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:hosting": "tsc -b && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:icon": "node scripts/build-icon.mjs",
    "build:app": "npm run build:web && npm run build:electron",
    "start:electron": "cross-env electron .",
    "pack": "npm run build:app && npm run build:icon && electron-builder",
    "dist:win": "npm run build:app && npm run build:icon && electron-builder --win && node scripts/verify-release.mjs",
    "release:win-and-web": "npm run dist:win && cross-env DEPLOY_SKIP_BUILD=1 npm run deploy:web",
    "dist:win:portable": "npm run build:app && npm run build:icon && cross-env ELECTRON_BUILDER_CACHE=C:/eb-cache electron-builder --win portable && node scripts/verify-release.mjs",
    "dist:win:signed": "npm run build:app && npm run build:icon && electron-builder --win --config.win.signAndEditExecutable=true && node scripts/verify-release.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "clean": "node scripts/clean.mjs",
    "check": "npm run typecheck && npm run test && npm run lint",
    "ci": "npm run typecheck && npm run test && npm run lint && npm run build:app && npm run build:icon && npm audit --audit-level=high",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "npx --yes @playwright/test@1.57.0 test",
    "test:integration:edge": "vitest run --config vitest.integration.config.ts",
    "preview": "vite preview",
    "license:keypair": "tsx scripts/generateDesktopLicenseKeyPair.ts",
    "license:generate": "tsx scripts/generateDesktopLicense.ts",
    "snapshot:export": "node scripts/export-iso-pro-snapshot.mjs",
    "snapshot:verify": "node scripts/verify-iso-pro-snapshot-export.mjs",
    "backup:upload-oci": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/upload-backup-to-oci.ps1",
    "deploy:web": "node scripts/deploy-web.mjs"
  },
  "dependencies": {
    "@sentry/react": "^9.22.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.99.0",
    "iso-pro-shared": "file:packages/iso-pro-shared",
    "jsbarcode": "^3.12.3",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}

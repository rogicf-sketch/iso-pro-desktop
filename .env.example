# Copie para `.env` na raiz (não commite segredos de produção).
# Variáveis VITE_* são embutidas no bundle web/desktop renderer.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Export manual de snapshot (npm run snapshot:export) — se omitir SUPABASE_*, o script usa VITE_* do .env.
# Para backup completo na nuvem, prefira service role / secret (Settings > API no Supabase):
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Opcional: observabilidade (DSN público do projecto Sentry — ainda assim não commite em repositório público sem RLS de acesso ao projecto).
VITE_SENTRY_DSN=
